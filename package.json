{
  "name": "harvestflow-openclaw-extension",
  "version": "1.0.0",
  "description": "OpenClaw Extension for HarvestFlow - AI Agent session data collection and curation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "harvestflow",
    "agent",
    "extension"
  ],
  "openclaw": {
    "extensions": [
      "dist/index.js"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "axios": "^1.6.0",
    "openclaw": "^2026.3.31",
    "typebox": "^1.1.12"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
